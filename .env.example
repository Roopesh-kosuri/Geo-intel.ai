# GeoIntel AI — Environment Variables
# Copy this file to .env and fill in your values

# Mapbox GL JS token (required for map)
# Get one free at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# NewsAPI key (optional — falls back to mock data)
# Get one free at https://newsapi.org/register
VITE_NEWS_API_KEY=your_newsapi_key_here
